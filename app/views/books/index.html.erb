<% content_for :title, "Books" %>

<h1><%= t(".title") %></h1>

<div id="books" class="row">
  <% @books.each do |book| %>
    <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
      <div class="card">
        <%= render book %>
        <%= link_to t("books.actions.show"), book %>
      </div>
    </div>
  <% end %>
</div>

<%= link_to t(".new"), new_book_path, class: "btn btn-primary" %>
