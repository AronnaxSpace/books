<%= form_with(model: book) do |form| %>
  <%= render("shared/errors", resource: book) if book.errors.any? %>

  <div class="form-group">
    <%= form.label :cover, style: "display: block", class: "form-label" %>
    <%= form.file_field :cover, class: "form-action" %>
  </div>

  <div class="form-group">
    <%= form.label :title, style: "display: block", class: "form-label" %>
    <%= form.text_field :title, class: "form-action" %>
  </div>

  <div class="form-group">
    <%= form.label :description, style: "display: block", class: "form-label" %>
    <%= form.text_area :description, class: "form-action" %>
  </div>

  <div class="form-group">
    <%= form.label :goodreads_url, style: "display: block", class: "form-label" %>
    <%= form.text_field :goodreads_url, class: "form-action" %>
  </div>

  <div class="form-group">
    <%= form.label :year, style: "display: block", class: "form-label" %>
    <%= form.number_field :year, class: "form-action" %>
  </div>

  <div>
    <%= form.submit nil, class: "btn btn-primary" %>
  </div>
<% end %>
